		{
			"_id": "ohsVSZTrfEnAOsmO",
			"_stats": {
				"compendiumSource": "Compendium.pf2e.spells-srd.Item.i35dpZFI7jZcRoBo",
				"duplicateSource": null,
				"exportSource": null,
				"coreVersion": "14.364",
