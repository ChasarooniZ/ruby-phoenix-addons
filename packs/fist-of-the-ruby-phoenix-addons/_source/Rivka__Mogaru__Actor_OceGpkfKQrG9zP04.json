		{
			"_id": "Dgemu26adQhYO2RF",
			"_stats": {
				"compendiumSource": "Compendium.pf2e.spells-srd.Item.vLA0q0WOK2YPuJs6",
				"duplicateSource": null,
				"exportSource": null,
				"coreVersion": "14.364",
