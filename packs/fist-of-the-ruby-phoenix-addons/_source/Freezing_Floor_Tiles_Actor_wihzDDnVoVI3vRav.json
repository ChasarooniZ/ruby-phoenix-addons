			"immunities": [
				{
					"type": "cold",
					"exceptions": []
				}
			],
			"stealth": {
				"details": "<p>+23 (expert) or @Check[perception|dc:38|traits:action:seek] (master) to notice the four sensors</p>",
				"value": 23
			},
			"weaknesses": [
				{
					"type": "fire",
					"value": 15,
					"exceptions": []
				}
			],
			"resistances": [],
			"emitsSound": "encounter"
		},
		"details": {
			"description": "<p>Four remote sensors at each corner of the arena cause bursts of freezing magic to erupt from random tiles on the arena and stop creatures in their tracks.</p>",
			"disable": "<p>@Check[thievery|dc:40|name:Disable One Sensor|traits:action:disable-a-device] (master) or @UUID[Compendium.pf2e.spells-srd.Item.9HpwDN4MYQJnW0LG]{Dispel Magic} (6th rank; counteract DC 38) to disable one of the sensors</p>",
			"isComplex": true,
			"level": {
				"value": 16
			},
			"publication": {
				"license": "OGL",
				"remaster": false,
				"title": "Pathfinder #167: Ready? Fight!",
				"authors": ""
			},
			"reset": "",
			"routine": "<p>(4 actions) The trap loses 1 action per disabled sensor. On each action, the trap causes a random 10-foot-by-10-foot space in the arena to suddenly freeze. Each creature that begins its turn in a frozen space takes @Damage[(3d12+18)[cold]] damage (@Check[reflex|dc:40|basic] save). A creature that critically fails its save also becomes @UUID[Compendium.pf2e.conditionitems.Item.xYTAsEpcJE1Ccni3]{Slowed 1} for 1 round; if it was already slowed, the creature instead becomes @UUID[Compendium.pf2e.conditionitems.Item.eIcWbB5o3pP6OIMe]{Immobilized} for 1 round. Any amount of fire damage dealt to a slowed or immobilized creature removes the condition. Frozen tiles become unfrozen at the beginning of the trap's next turn.</p>"
		},
