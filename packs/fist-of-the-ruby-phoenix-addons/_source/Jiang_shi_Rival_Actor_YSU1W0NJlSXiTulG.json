		{
			"_id": "L4ewcxHDWUZozOIs",
			"_stats": {
				"compendiumSource": "Compendium.pf2e.bestiary-family-ability-glossary.Item.R1vYhCJ2KvT8uAy1",
				"duplicateSource": null,
				"exportSource": null,
				"coreVersion": "14.364",
